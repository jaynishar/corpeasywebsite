# ═══════════════════════════════════════════════════════════════════
# CORPEASY HOSTINGER OPTIMIZATION
# ═══════════════════════════════════════════════════════════════════

RewriteEngine On
RewriteBase /

# SPA: serve index.php for all non-file requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!admin_simple\.php|submit\.php|get_posts\.php|sitemap\.xml|robots\.txt).*$ index.php [L]

# Prevent directory listing
Options -Indexes

# Custom error page
ErrorDocument 404 /index.php
